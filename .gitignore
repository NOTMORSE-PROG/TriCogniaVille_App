# Godot 4 .gitignore

# Godot-generated files and folders
.godot/
*.import

# Android build output
android/build/
*.apk
*.aab

# Godot keystore credentials (Godot 4.3+ — secrets live here, not in export_presets.cfg)
.godot/export_credentials.cfg

# Plugin build artifacts
_plugin_build/

# Claude Code Game Studios (AI framework — not game source)
.claude/

# Backend (separate repo)
backend/

# Secrets
app_config.cfg
client_secret_*.json
*.pem
*.keystore
.env*

# Dependencies
node_modules/

# Production logs
production/session-logs/

# Documents & media (not game assets)
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx
*.csv

# Archives
*.zip
*.rar
*.7z
*.tar.gz

# Images (non-asset)
*.psd
*.ai
*.sketch

# Logs
*.log

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# OS-generated
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Windows temp files
~*
*.TMP
